{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@mh/core/agent": ["packages/core/src/agent/index.ts"],
      "@mh/core/llm": ["packages/core/src/llm/index.ts"],
      "@mh/core/tools": ["packages/core/src/tools/index.ts"],
      "@mh/core/data": ["packages/core/src/data/index.ts"],
      "@mh/core/shared": ["packages/core/src/shared/index.ts"]
    }
  }
}
